#!/usr/bin/env bash
# pre-push: run local tests before any push.
# Blocks direct push to main (branch protection mirrors this server-side too).

set -euo pipefail

REMOTE="$1"
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# Block direct push to main — must go through PR.
if [[ "$BRANCH" == "main" ]]; then
  echo ""
  echo "✗ Direct push to main is blocked."
  echo "  Create a branch and open a PR:"
  echo "    git checkout -b feat/my-change"
  echo "    git push -u origin feat/my-change"
  echo "    gh pr create"
  echo ""
  exit 1
fi

echo "→ Running backend tests (with coverage gate ≥80%)..."

cd "$(git rev-parse --show-toplevel)/backend"

go test \
  ./internal/transport/http/... \
  ./internal/middleware/... \
  -coverprofile=coverage.out -covermode=atomic -timeout 30s

COVERAGE=$(go tool cover -func=coverage.out | grep total | awk '{print $3}' | tr -d '%')
echo "  Coverage: ${COVERAGE}%"

if [ "$(echo "$COVERAGE < 80" | bc -l)" -eq 1 ]; then
  echo ""
  echo "✗ Coverage ${COVERAGE}% is below 80%. Add tests before pushing."
  echo ""
  exit 1
fi

echo "✓ Backend tests passed (${COVERAGE}% coverage)"

echo "→ Running frontend lint + build..."
cd ../frontend
npm run lint --silent && npm run build --silent
echo "✓ Frontend OK"

echo "→ Running integration smoke tests (agent-browser)..."
cd ..
bash scripts/integration-test.sh
echo "✓ Integration tests passed"

echo ""
echo "✓ All checks passed — pushing to $REMOTE ($BRANCH)"
echo ""
