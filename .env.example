# Local dev only — copy to .env.local
POSTGRES_USER=mylifeos
POSTGRES_PASSWORD=mylifeos
POSTGRES_DB=mylifeos
# Backend DB connection — use service name "postgres" inside docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_USER=mylifeos
DB_PASSWORD=mylifeos
DB_NAME=mylifeos

# Set to "development" locally — skips real JWT validation
ENV=development
DEV_USER_ID=00000000-0000-0000-0000-000000000001
PORT=8080

# Supabase (production only)
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend
VITE_API_URL=http://localhost:8080/api/v1
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
